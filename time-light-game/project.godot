; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="TimeLightGame"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://Resources/icon.svg"

[audio]

buses/default_bus_layout="uid://bakxmud250avq"

[autoload]

Global="*uid://b0obqlkwt0opv"
SignalBus="*uid://bt0aw8wv577hy"
SceneChanger="*uid://bqe1a0jxnaoyd"
Util="*uid://bfdq2honfh70u"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/kanban_tasks/plugin.cfg")

[file_customization]

folder_colors={
"res://Assets/": "blue",
"res://Assets/Player/": "purple",
"res://GameScenes/": "yellow",
"res://Resources/": "orange"
}

